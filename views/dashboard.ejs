<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Chicago Crime Intelligence | Smart Policing</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: #0b0c10;
  color: #c5c6c7;
  font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  padding-bottom: 50px;
}

/* TOP HEADER */
.header {
  padding: 24px 32px 0 32px;
  border-bottom: 1px solid #1f2833;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24px;
  flex-wrap: wrap;
  gap: 16px;
}

.title-main h1 {
  font-size: 20px;
  letter-spacing: 2px;
  color: #fff;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.title-main h2 {
  font-size: 13px;
  color: #8892b0;
  letter-spacing: 1.5px;
  font-weight: 500;
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 16px;
  font-family: monospace;
  font-size: 13px;
  flex-wrap: wrap;
}

.status-badge .records {
  color: #8892b0;
}

.badge {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
  padding: 6px 12px;
  border-radius: 20px;
  border: 1px solid rgba(76, 175, 80, 0.3);
}

.badge::before {
  content: "";
  width: 8px;
  height: 8px;
  background: #4caf50;
  border-radius: 50%;
  box-shadow: 0 0 8px #4caf50;
}

.tabs {
  display: flex;
  gap: 32px;
  overflow-x: auto;
  white-space: nowrap;
}

.tab {
  padding: 12px 0;
  color: #8892b0;
  font-size: 13px;
  letter-spacing: 1.5px;
  font-weight: 600;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}

.tab:hover {
  color: #fff;
}

.tab.active {
  color: #66fcf1;
  border-bottom: 2px solid #66fcf1;
}

/* MAIN LAYOUT */
.container {
  padding: 32px;
  max-width: 1400px;
  margin: 0 auto;
}

.tab-content {
  display: none;
  animation: fadeIn 0.3s ease;
}

.tab-content.active-content {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(5px); }
  to { opacity: 1; transform: translateY(0); }
}

.grid {
  display: grid;
  grid-template-columns: 350px 1fr;
  gap: 32px;
}

/* CARDS */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.card {
  background: #11141a;
  border: 1px solid #1f2833;
  border-radius: 8px;
  padding: 20px;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
}

.card-red::before { background: #f44336; }
.card-blue::before { background: #2196f3; }
.card-orange::before { background: #ff9800; }
.card-green::before { background: #4caf50; }
.card-purple::before { background: #9c27b0; }

.card h3 {
  font-size: 11px;
  color: #8892b0;
  letter-spacing: 1.5px;
  margin-bottom: 16px;
  text-transform: uppercase;
}

.card .value {
  font-size: 32px;
  font-weight: 800;
  margin-bottom: 4px;
}

.card .label {
  font-size: 12px;
  color: #8892b0;
}

/* Map area */
.map-container {
  background: #11141a;
  border: 1px solid #1f2833;
  border-radius: 8px;
  padding: 24px;
  height: 100%;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
}

.section-header h3 {
  font-size: 13px;
  letter-spacing: 2px;
  color: #8892b0;
  text-transform: uppercase;
}

.section-header p {
  font-size: 13px;
  color: #c5c6c7;
  font-family: monospace;
}

.map-placeholder {
  width: 100%;
  height: 400px;
  background: #0b0c10;
  border: 1px solid #1f2833;
  border-radius: 4px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* Chart.js styling tweaks inside canvas */
.eda-container {
  background: #11141a;
  border: 1px solid #1f2833;
  border-radius: 8px;
  padding: 24px;
  margin-top: 32px;
}

.charts-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
  height: 200px;
}

/* Logout button */
.logout-btn {
  position: fixed;
  bottom: 24px;
  right: 32px;
  background: #11141a;
  border: 1px solid #f44336;
  color: #f44336;
  padding: 8px 16px;
  border-radius: 4px;
  font-size: 12px;
  letter-spacing: 1px;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.2s;
  z-index: 100;
}

.logout-btn:hover {
  background: #f44336;
  color: #fff;
}

/* RESPONSIVE DESIGN */
@media (max-width: 1024px) {
  .grid {
    grid-template-columns: 1fr;
  }
  .charts-row {
    grid-template-columns: 1fr;
    height: auto;
  }
  .charts-row > div {
    height: 200px;
  }
  .map-placeholder {
    height: 300px;
  }
}

@media (max-width: 768px) {
  .stats-grid {
    grid-template-columns: 1fr;
  }
  .card[style] {
    grid-column: span 1 !important;
  }
  .title-row {
    flex-direction: column;
    align-items: flex-start;
  }
  .tabs {
    gap: 16px;
  }
}
</style>
</head>
<body>

<div class="header">
  <div class="title-row">
    <div class="title-main">
      <h1>CHICAGO CRIME INTELLIGENCE</h1>
      <h2>SMART POLICING SYSTEM · v1.0</h2>
    </div>
    <div class="status-badge">
      <span class="records">123,561 RECORDS ANALYSED</span>
      <div class="badge">MODEL ACTIVE</div>
      <div style="color: #fff;">Agent: <%= user.name %></div>
    </div>
  </div>
  <div class="tabs">
    <div class="tab active" data-target="tab-overview">OVERVIEW</div>
    <div class="tab" data-target="tab-crimemap">CRIME MAP</div>
    <div class="tab" data-target="tab-performance">MODEL PERFORMANCE</div>
    <div class="tab" data-target="tab-predictions">LOG PREDICTIONS</div>
  </div>
</div>

<div class="container">
  
  <!-- TAB CONTENT: OVERVIEW -->
  <div id="tab-overview" class="tab-content active-content">
    <div class="grid">
      <!-- LEFT COLUMN: STATS -->
      <div>
        <div class="stats-grid">
          <div class="card card-red" style="grid-column: span 2;">
            <h3>TOTAL CRIMES</h3>
            <div class="value" style="color: #f44336;">0.12M</div>
            <div class="label">Records analysed</div>
          </div>

          <div class="card card-blue" style="grid-column: span 2;">
            <h3>GRID CELLS</h3>
            <div class="value" style="color: #2196f3;">2,388</div>
            <div class="label">~500m each</div>
          </div>

          <div class="card card-orange">
            <h3>HOTSPOT CELLS</h3>
            <div class="value" style="color: #ff9800;">598</div>
            <div class="label">Top 25% risk zones</div>
          </div>

          <div class="card card-green">
            <h3>ROC-AUC</h3>
            <div class="value" style="color: #4caf50;">0.9902</div>
            <div class="label">Classifier score</div>
          </div>

          <div class="card card-purple" style="grid-column: span 2;">
            <h3>R² SCORE</h3>
            <div class="value" style="color: #9c27b0;">0.9324</div>
            <div class="label">Regressor score</div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN: SCATTER MAP -->
      <div>
        <div class="map-container">
          <div class="section-header">
            <h3>CRIME DENSITY SCATTER</h3>
            <p>Red = hotspot zones</p>
          </div>
          <div class="map-placeholder">
            <canvas id="mapChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- BOTTOM: EDA OVERVIEW -->
    <div class="eda-container">
      <div class="section-header">
        <h3>EDA OVERVIEW</h3>
      </div>
      <div class="charts-row">
        <div><canvas id="chart1"></canvas></div>
        <div><canvas id="chart2"></canvas></div>
        <div><canvas id="chart3"></canvas></div>
      </div>
    </div>
  </div>

  <!-- TAB CONTENT: CRIME MAP -->
  <div id="tab-crimemap" class="tab-content">
    <div class="map-container" style="padding: 0; overflow: hidden; height: 75vh;">
      <iframe src="/crime-dashboard" width="100%" height="100%" style="border: none; border-radius: 8px;"></iframe>
    </div>
  </div>

  <!-- TAB CONTENT: MODEL PERFORMANCE -->
  <div id="tab-performance" class="tab-content">
    <div class="card card-blue" style="margin-bottom: 24px;">
      <h3>Model Health API</h3>
      <div class="value" id="model-health" style="font-size: 18px; color: #fff;">Checking...</div>
    </div>
    <div class="grid">
      <div class="card card-green">
        <h3>Classifier (ROC-AUC)</h3>
        <div class="value" style="color: #4caf50;">0.9902</div>
        <div class="label">XGBoost Classification</div>
      </div>
      <div class="card card-purple">
        <h3>Regressor (R² Score)</h3>
        <div class="value" style="color: #9c27b0;">0.9324</div>
        <div class="label">XGBoost Regression</div>
      </div>
    </div>
  </div>

  <!-- TAB CONTENT: LOG PREDICTIONS -->
  <div id="tab-predictions" class="tab-content">
    <div class="card card-orange" style="max-width: 600px; margin: 0 auto;">
      <h3>Log New Prediction</h3>
      <div style="margin-top: 16px;">
        <label style="display:block; margin-bottom: 8px; color: #8892b0; font-size: 12px;">Latitude</label>
        <input type="text" id="lat-input" placeholder="e.g. 41.85" style="width: 100%; padding: 12px; background: #0b0c10; border: 1px solid #1f2833; color: #fff; border-radius: 4px; margin-bottom: 16px;" />
        
        <label style="display:block; margin-bottom: 8px; color: #8892b0; font-size: 12px;">Longitude</label>
        <input type="text" id="lon-input" placeholder="e.g. -87.65" style="width: 100%; padding: 12px; background: #0b0c10; border: 1px solid #1f2833; color: #fff; border-radius: 4px; margin-bottom: 24px;" />
        
        <button id="predict-btn" style="background: #ff9800; color: #000; border: none; padding: 12px 24px; font-weight: bold; border-radius: 4px; cursor: pointer; width: 100%;">RUN PREDICTION</button>

        <div id="predict-result" style="margin-top: 24px; font-family: monospace; color: #66fcf1;"></div>
      </div>
    </div>
  </div>

</div>

<a href="/logout" class="logout-btn">LOG OUT</a>

<script>
// --- TAB SWITCHING LOGIC ---
const tabs = document.querySelectorAll('.tab');
const tabContents = document.querySelectorAll('.tab-content');

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    // Remove active class from all tabs
    tabs.forEach(t => t.classList.remove('active'));
    tabContents.forEach(c => c.classList.remove('active-content'));

    // Add active class to clicked tab
    tab.classList.add('active');
    
    // Show corresponding content
    const targetId = tab.getAttribute('data-target');
    document.getElementById(targetId).classList.add('active-content');
  });
});

// --- MODEL API INTEGRATION ---
// Fetch Health
fetch('/model/health')
  .then(res => res.json())
  .then(data => {
    const el = document.getElementById('model-health');
    if(data.status === 'ok') {
      el.innerHTML = '✅ API Online (XGBoost Active)';
      el.style.color = '#4caf50';
    } else {
      el.innerHTML = '❌ API Unavailable';
      el.style.color = '#f44336';
    }
  })
  .catch(err => {
    document.getElementById('model-health').innerHTML = '❌ Connection Failed';
    document.getElementById('model-health').style.color = '#f44336';
  });

// Run Prediction
document.getElementById('predict-btn').addEventListener('click', () => {
  const lat = document.getElementById('lat-input').value;
  const lon = document.getElementById('lon-input').value;
  const resEl = document.getElementById('predict-result');
  
  if(!lat || !lon) {
    resEl.innerHTML = 'Please enter both coordinates.';
    resEl.style.color = '#f44336';
    return;
  }
  
  resEl.innerHTML = 'Analyzing grid matrix...';
  resEl.style.color = '#8892b0';

  fetch(`/model/predict?lat=${lat}&lon=${lon}`)
    .then(res => res.json())
    .then(data => {
      if(data.error) {
        resEl.innerHTML = 'Error: ' + data.error;
        resEl.style.color = '#f44336';
      } else {
        resEl.innerHTML = `> Prediction Complete <br><br>Hotspot: <span style="color: ${data.is_hotspot ? '#f44336' : '#4caf50'}">${data.is_hotspot ? 'YES' : 'NO'}</span><br>Predicted Crimes: <span style="color: #66fcf1">${Math.round(data.predicted_crimes)}</span>`;
      }
    })
    .catch(err => {
      resEl.innerHTML = 'Failed to reach prediction API.';
      resEl.style.color = '#f44336';
    });
});

// --- CHART.JS CONFIGURATION ---
Chart.defaults.color = '#8892b0';
Chart.defaults.font.family = 'Inter';
Chart.defaults.scale.grid.color = 'rgba(255,255,255,0.05)';

// Generate Fake Map Data for Scatter Plot
const mapData = [];
for(let i=0; i<800; i++) {
  const lat = 41.65 + Math.random() * 0.4;
  const lng = -87.90 + Math.random() * 0.35;
  const dist = Math.sqrt(Math.pow(lat - 41.85, 2) + Math.pow(lng - -87.65, 2));
  if(Math.random() > dist * 3) {
    mapData.push({ x: lng, y: lat, v: Math.random() });
  }
}

new Chart(document.getElementById('mapChart'), {
  type: 'scatter',
  data: {
    datasets: [{
      data: mapData,
      backgroundColor: (ctx) => {
        const v = ctx.raw ? ctx.raw.v : 0;
        return v > 0.8 ? '#f44336' : (v > 0.5 ? '#ff9800' : '#2196f3');
      },
      pointRadius: 2
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, tooltip: { enabled: false } },
    scales: {
      x: { title: { display: true, text: 'Longitude' } },
      y: { title: { display: true, text: 'Latitude' } }
    }
  }
});

// Chart 1: Crimes by Hour
new Chart(document.getElementById('chart1'), {
  type: 'bar',
  data: {
    labels: Array.from({length: 24}, (_, i) => i),
    datasets: [{
      label: 'Crimes by Hour',
      data: [15,12,10,8,7,6,8,12,18,22,25,28,30,32,31,34,35,33,29,25,22,20,18,16],
      backgroundColor: '#2196f3'
    }]
  },
  options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
});

// Chart 2: Crimes by Day
new Chart(document.getElementById('chart2'), {
  type: 'bar',
  data: {
    labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
    datasets: [{
      label: 'Crimes by Day',
      data: [120, 125, 122, 130, 150, 160, 140],
      backgroundColor: '#4caf50'
    }]
  },
  options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
});

// Chart 3: Crimes by Year
new Chart(document.getElementById('chart3'), {
  type: 'line',
  data: {
    labels: ['2019','2020','2021','2022','2023'],
    datasets: [{
      label: 'Crimes by Year',
      data: [350000, 280000, 290000, 295000, 285000],
      borderColor: '#f44336',
      tension: 0.4
    }]
  },
  options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
});
</script>

</body>
</html>