<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CrimeIntel | Command Dashboard</title>

<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  height: 100vh;
  font-family: "Inter", "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 30% 20%, rgba(255,0,0,0.15), transparent 40%),
    linear-gradient(#050608, #050608);
  color: #eaeaea;
  overflow: hidden;
}

/* GRID */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
}

/* TOP BAR */
.topbar {
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.logo {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: 2px;
}
.logo span { color: #e53935; }

.agent {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 14px;
}

/* AVATAR */
.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #e53935;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  overflow: hidden;
}
.avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* MAIN */
.main {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
  padding: 32px;
  height: calc(100vh - 64px);
}

/* PANELS */
.panel {
  background: rgba(15,17,22,0.95);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 24px;
  box-shadow: 0 0 40px rgba(229,57,53,.12);
}

.panel h3 {
  font-size: 14px;
  letter-spacing: 2px;
  margin-bottom: 18px;
  color: #aaa;
}

/* INFO ROWS */
.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
  font-size: 14px;
}
.row span:last-child {
  color: #fff;
  font-weight: 600;
}

/* STATUS */
.status {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: #9f9f9f;
}
.status::before {
  content: "";
  width: 10px;
  height: 10px;
  background: #e53935;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(229,57,53,.7); }
  70% { box-shadow: 0 0 0 12px rgba(229,57,53,0); }
  100% { box-shadow: 0 0 0 0 rgba(229,57,53,0); }
}

/* FAKE DATA */
.metric {
  font-size: 34px;
  font-weight: 800;
  color: #e53935;
}
.small {
  font-size: 13px;
  color: #aaa;
}

/* LOG */
.log {
  font-size: 13px;
  color: #bbb;
  line-height: 1.6;
}

/* LOGOUT */
.logout {
  position: absolute;
  bottom: 24px;
  right: 32px;
  padding: 10px 22px;
  background: transparent;
  border: 1px solid #e53935;
  color: #e53935;
  border-radius: 6px;
  cursor: pointer;
}
.logout:hover {
  background: #e53935;
  color: #fff;
}
</style>
</head>

<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="logo">CRIME<span>INTEL</span></div>

  <div class="agent">
    <div class="avatar">
      <% if (user.avatar) { %>
        <img src="<%= user.avatar %>" />
      <% } else { %>
        <%= user.name.charAt(0).toUpperCase() %>
      <% } %>
    </div>
    <div>
      <div><%= user.name %></div>
      <small><%= user.email %></small>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- AGENT PANEL -->
  <div class="panel">
    <h3>AGENT PROFILE</h3>
    <div class="row"><span>Name</span><span><%= user.name %></span></div>
    <div class="row"><span>Email</span><span><%= user.email %></span></div>
    <div class="row">
      <span>Auth Method</span>
      <span><%= user.googleId ? "Google Secure Auth" : "Local Credentials" %></span>
    </div>
    <div class="row">
      <span>Joined</span>
      <span><%= new Date(user.createdAt).toLocaleDateString() %></span>
    </div>
    <div class="status">ACTIVE CLEARANCE · MONITORED</div>
  </div>

  <!-- HOTSPOT PANEL -->
  <div class="panel">
    <h3>CRIME HOTSPOTS</h3>
    <div class="metric">23</div>
    <div class="small">Active high-risk zones detected</div>
    <br>
    <div class="metric">+14%</div>
    <div class="small">Spike in urban incidents (last 24h)</div>
  </div>

  <!-- SYSTEM LOG -->
  <div class="panel">
    <h3>SYSTEM LOG</h3>
    <div class="log">
      ▸ Spark analytics pipeline online<br>
      ▸ CV model scanning CCTV feeds<br>
      ▸ Heatmap generation running<br>
      ▸ Predictive policing model synced<br>
      ▸ All actions logged & audited
    </div>
  </div>

</div>

<a href="/logout"><button class="logout">LOG OUT</button></a>

</body>
</html>