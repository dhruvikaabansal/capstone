<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CrimeIntel | Secure Access</title>

<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  height: 100vh;
  font-family: "Inter", "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 20% 20%, rgba(255,0,0,0.12), transparent 40%),
    linear-gradient(#050608, #050608);
  color: #eaeaea;
  overflow: hidden;
}

/* ── GRID OVERLAY ── */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
}

/* ── LAYOUT ── */
.wrapper {
  height: 100%;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
}

/* ── LEFT PANEL ── */
.left {
  padding: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand {
  font-size: 56px;
  font-weight: 800;
  letter-spacing: 3px;
}
.brand span { color: #e53935; }

.tagline {
  max-width: 520px;
  margin-top: 20px;
  color: #b0b0b0;
  line-height: 1.6;
}

.status {
  margin-top: 30px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: #9f9f9f;
}

.status::before {
  content: "";
  width: 10px;
  height: 10px;
  background: #e53935;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(229,57,53,.7); }
  70% { box-shadow: 0 0 0 12px rgba(229,57,53,0); }
  100% { box-shadow: 0 0 0 0 rgba(229,57,53,0); }
}

/* ── RIGHT PANEL ── */
.right {
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  width: 380px;
  background: rgba(15,17,22,0.95);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 40px;
  border-radius: 12px;
  box-shadow: 0 0 40px rgba(229,57,53,.15);
}

.card h2 {
  letter-spacing: 2px;
  margin-bottom: 6px;
}

.card p {
  font-size: 13px;
  color: #999;
  margin-bottom: 26px;
}

label {
  font-size: 12px;
  letter-spacing: 1px;
  color: #aaa;
}

input {
  width: 100%;
  margin-top: 6px;
  margin-bottom: 18px;
  padding: 12px;
  background: #080a0f;
  border: 1px solid #333;
  color: #fff;
  border-radius: 6px;
}

input:focus {
  border-color: #e53935;
  outline: none;
}

.btn {
  width: 100%;
  padding: 12px;
  background: #e53935;
  color: white;
  border: none;
  border-radius: 6px;
  font-weight: 700;
  cursor: pointer;
}

.btn:hover { background: #ff3b3b; }

.google {
  margin-top: 14px;
  background: transparent;
  border: 1px solid #444;
}

.links {
  margin-top: 20px;
  text-align: center;
  font-size: 13px;
}

.links a {
  color: #e53935;
  text-decoration: none;
}
</style>
</head>

<body>
<div class="wrapper">

  <div class="left">
    <div class="brand">CRIME<span>INTEL</span></div>
    <div class="tagline">
      Advanced urban crime intelligence system using Computer Vision,
      Spark analytics and Machine Learning to identify hotspots and
      enable smart policing.
    </div>
    <div class="status">SYSTEM LIVE · ALL ACTIVITY MONITORED</div>
  </div>

  <div class="right">
    <div class="card">
      <h2>SECURE ACCESS</h2>
      <p>Authorized personnel only</p>

      <form action="/login" method="POST">
        <label>AGENT EMAIL</label>
        <input type="email" name="email" required>

        <label>SECURITY KEY</label>
        <input type="password" name="password" required>

        <button class="btn">AUTHORIZE ACCESS</button>
      </form>

      <a href="/auth/google">
        <button class="btn google">GOOGLE SECURE AUTH</button>
      </a>

      <div class="links">
        New agent? <a href="/signup">Request Access</a>
      </div>
    </div>
  </div>

</div>
</body>
</html>